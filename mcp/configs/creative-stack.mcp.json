{
  "$schema": "https://modelcontextprotocol.io/schemas/mcp-servers.json",
  "_note": "Rename to `.mcp.json` in your project root (dotfiles were blocked in the authoring environment). Merge the `mcpServers` block into `~/.claude.json` for global availability.",
  "mcpServers": {
    "palette-oklch": {
      "command": "node",
      "args": ["./mcp/servers/palette-oklch/dist/index.js"]
    },
    "sprite-packer": {
      "command": "node",
      "args": ["./mcp/servers/sprite-packer/dist/index.js"]
    },
    "asset-router": {
      "command": "node",
      "args": ["./mcp/servers/asset-router/dist/index.js"],
      "env": {
        "REPLICATE_API_TOKEN": "${REPLICATE_API_TOKEN:-}",
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY:-}",
        "FAL_KEY": "${FAL_KEY:-}",
        "SUNO_API_KEY": "${SUNO_API_KEY:-}",
        "LUMAAI_API_KEY": "${LUMAAI_API_KEY:-}",
        "RUNWAY_API_KEY": "${RUNWAY_API_KEY:-}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    },
    "git": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    }
  }
}
