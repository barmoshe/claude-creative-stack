{
  "name": "sprite-packer-mcp",
  "version": "0.1.0",
  "description": "MCP server that packs PNG sprite frames into a single atlas + JSON manifest. Mirrors skills/sprite-atlas-builder/scripts/pack.ts.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sprite-packer-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
