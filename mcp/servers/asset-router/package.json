{
  "name": "asset-router-mcp",
  "version": "0.1.0",
  "description": "MCP server that routes image / voice / music / video generation to Replicate, Fal, ElevenLabs, Suno, or Luma. Falls back to a deterministic stub when API keys are missing.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "asset-router-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
