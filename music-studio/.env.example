# Copy to .env (gitignored) and fill in.
# Get keys from:
#   ElevenLabs:    https://elevenlabs.io/app/settings/api-keys
#   YouTube Data:  Google Cloud Console → APIs & Services → Credentials
#   Anthropic:     https://console.anthropic.com/

ELEVENLABS_API_KEY=
YOUTUBE_API_KEY=

# Only needed if running scripts that call the Anthropic API directly.
# The artifact endpoint api.anthropic.com/v1/messages is keyless inside artifacts.
# ANTHROPIC_API_KEY=
