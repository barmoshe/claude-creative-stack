{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_note": "Repo-shipped hooks. See knowledge/16-hooks-and-retrieval.md. UserPromptSubmit retrieval is intentionally un-registered; opt in by uncommenting the example in the knowledge file.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/save-issues.mjs"
          }
        ]
      }
    ]
  }
}
